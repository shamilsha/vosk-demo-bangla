<?xml version="1.0" encoding="utf-8"?>
<!-- Conveyor/ribbon window: thin border, fixed slot where ribbon moves (items enter top, exit bottom). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/lesson_box_background" />
    <stroke
        android:width="1dp"
        android:color="@color/lesson_box_stroke" />
    <corners android:radius="2dp" />
</shape>
