<?xml version="1.0" encoding="utf-8"?>
<!-- POC: iPhone-style list button with high contrast (square-ish rounded corners). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0D47A1" />
            <stroke android:width="1dp" android:color="#08306B" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1565C0" />
            <stroke android:width="1dp" android:color="#0D47A1" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
