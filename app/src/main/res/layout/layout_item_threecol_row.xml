<?xml version="1.0" encoding="utf-8"?>
<!-- One row for 3-column data displayed as 2 columns: Bengali | English + Hint. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@android:color/transparent">

    <!-- Left: Bengali + fixed-width tick/cross mark (does not change layout width). -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingVertical="2dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/threecol_status_mark"
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/threecol_bengali"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Right: English + Hint stacked + status icon -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingVertical="2dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/threecol_english"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lesson_topic_bar_background"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/threecol_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontStyle="italic" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>

