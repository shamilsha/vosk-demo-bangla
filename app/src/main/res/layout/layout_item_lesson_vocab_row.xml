<?xml version="1.0" encoding="utf-8"?>
<!-- One row: table-style Word | Pronunciation | Meaning | You said + result icon. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="100"
    android:gravity="center_vertical"
    android:baselineAligned="false"
    android:paddingVertical="0dp"
    android:paddingHorizontal="0dp"
    android:minHeight="36dp">

    <TextView
        android:id="@+id/lesson_vocab_word"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="20"
        android:background="@drawable/bg_tense_triplet_cell"
        android:gravity="center_vertical"
        android:padding="3dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:ellipsize="end"
        android:maxLines="2" />

    <TextView
        android:id="@+id/lesson_vocab_pronunciation"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="20"
        android:background="@drawable/bg_tense_triplet_cell"
        android:gravity="center_vertical"
        android:padding="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:ellipsize="end"
        android:maxLines="2" />

    <TextView
        android:id="@+id/lesson_vocab_meaning"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="35"
        android:background="@drawable/bg_tense_triplet_cell"
        android:gravity="center_vertical"
        android:padding="3dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:ellipsize="end"
        android:maxLines="2" />

    <LinearLayout
        android:id="@+id/lesson_vocab_spoken_cell"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:minHeight="36dp"
        android:layout_weight="25"
        android:background="@drawable/bg_tense_triplet_cell"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:paddingHorizontal="3dp">

        <TextView
            android:id="@+id/lesson_vocab_spoken"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageView
            android:id="@+id/lesson_vocab_result_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="Pass or fail"
            android:visibility="invisible"
            android:scaleType="fitCenter" />
    </LinearLayout>
</LinearLayout>
