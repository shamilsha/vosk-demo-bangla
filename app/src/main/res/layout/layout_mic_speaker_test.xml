<?xml version="1.0" encoding="utf-8"?>
<!-- Mic / Speaker test: language radios, record, editable text, copy/speak/clear, optional waveform -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Bengali and English in one row (black text) -->
    <RadioGroup
        android:id="@+id/mic_test_lang_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">
        <RadioButton
            android:id="@+id/mic_test_radio_bengali"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Bengali"
            android:textSize="16sp"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:checked="true" />
        <RadioButton
            android:id="@+id/mic_test_radio_english"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="English"
            android:textSize="16sp"
            android:textColor="#000000"
            android:buttonTint="#000000" />
    </RadioGroup>

    <!-- Waveform / level bar (visible during recording) -->
    <ProgressBar
        android:id="@+id/mic_test_waveform"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <!-- Editable text area (gets most space; stays visible when keyboard opens) -->
    <EditText
        android:id="@+id/mic_test_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="100dp"
        android:gravity="top|start"
        android:padding="12dp"
        android:background="@color/lesson_box_background"
        android:hint="Tap record and speak…"
        android:textColorHint="#BDBDBD"
        android:textSize="16sp"
        android:textColor="#212121"
        android:inputType="textMultiLine|textCapSentences"
        android:scrollbars="vertical"
        android:imeOptions="actionDone" />

    <!-- Copy, Speaker, Clear -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/mic_test_copy"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy"
            android:scaleType="centerInside"
            android:src="@drawable/ic_content_copy" />
        <ImageButton
            android:id="@+id/mic_test_speaker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Speak"
            android:scaleType="centerInside"
            android:src="@drawable/ic_speak_english" />
        <ImageButton
            android:id="@+id/mic_test_clear"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear"
            android:scaleType="centerInside"
            android:src="@drawable/ic_clear" />
    </LinearLayout>

    <!-- Stop, Resume, Restart row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/mic_test_stop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Stop"
            android:textColor="#000000"
            android:textSize="14sp" />
        <Button
            android:id="@+id/mic_test_resume"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Resume"
            android:textColor="#000000"
            android:textSize="14sp" />
        <Button
            android:id="@+id/mic_test_restart"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Restart"
            android:textColor="#000000"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/mic_test_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select language, then tap record"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:paddingBottom="8dp" />
</LinearLayout>
