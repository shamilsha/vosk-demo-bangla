<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/triplet_present_cell"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_tense_triplet_cell"
            android:padding="6dp">

            <FrameLayout
                android:id="@+id/triplet_present_english_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/triplet_present_english"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <ImageView
                    android:id="@+id/triplet_present_english_mark"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="end|center_vertical"
                    android:visibility="invisible"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/triplet_present_bengali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <ImageView
                    android:id="@+id/triplet_present_bengali_mark"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="end|center_vertical"
                    android:visibility="invisible"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:id="@+id/triplet_present_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/triplet_past_cell"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_tense_triplet_cell"
            android:padding="6dp">

            <FrameLayout
                android:id="@+id/triplet_past_english_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/triplet_past_english"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <ImageView
                    android:id="@+id/triplet_past_english_mark"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="end|center_vertical"
                    android:visibility="invisible"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/triplet_past_bengali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
                <ImageView
                    android:id="@+id/triplet_past_bengali_mark"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="end|center_vertical"
                    android:visibility="invisible"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:id="@+id/triplet_past_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/triplet_future_cell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_tense_triplet_cell"
        android:padding="6dp"
        android:layout_marginTop="0dp">

        <FrameLayout
            android:id="@+id/triplet_future_english_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/triplet_future_english"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
            <ImageView
                android:id="@+id/triplet_future_english_mark"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="end|center_vertical"
                android:visibility="invisible"
                android:importantForAccessibility="no"
                android:contentDescription="@null" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/triplet_future_bengali"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
            <ImageView
                android:id="@+id/triplet_future_bengali_mark"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="end|center_vertical"
                android:visibility="invisible"
                android:importantForAccessibility="no"
                android:contentDescription="@null" />
        </FrameLayout>

        <TextView
            android:id="@+id/triplet_future_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
