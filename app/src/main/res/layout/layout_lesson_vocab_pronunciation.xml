<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable: 4-column vocabulary list (Word | Pronunciation | Meaning | You said) for V tab. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/lesson_vocab_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lesson_box_background"
    android:clipChildren="false">

    <!-- Header row: table-style 4 columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="100"
        android:gravity="center_vertical"
        android:background="@color/icon_row_background"
        android:padding="0dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="20"
            android:background="@drawable/bg_tense_triplet_cell"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:paddingHorizontal="4dp"
            android:text="Word"
            android:textColor="@color/lesson_topic_bar_background"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="20"
            android:background="@drawable/bg_tense_triplet_cell"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:paddingHorizontal="4dp"
            android:text="Pronunciation"
            android:textColor="@color/lesson_topic_bar_background"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="35"
            android:background="@drawable/bg_tense_triplet_cell"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:paddingHorizontal="4dp"
            android:text="Meaning"
            android:textColor="@color/lesson_topic_bar_background"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="25"
            android:background="@drawable/bg_tense_triplet_cell"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:paddingHorizontal="4dp"
            android:text="You said"
            android:textColor="@color/lesson_topic_bar_background"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Toggle: off = only untested/failed words; on = all words -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:background="@color/lesson_box_background">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show all words"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/lesson_vocab_show_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            app:trackTint="@color/lesson_vocab_switch_track"
            app:thumbTint="@color/lesson_vocab_switch_thumb" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lesson_vocab_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="0dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:overScrollMode="ifContentScrolls" />
</LinearLayout>
