<?xml version="1.0" encoding="utf-8"?>
<!-- Inflated into lesson_base_content only — mode tabs live in layout_lesson_mode_bar (shell). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/lecture_learning_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <TextView
            android:id="@+id/lecture_paragraph_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp"
            android:textColor="#1F2937"
            android:textSize="18sp" />
    </ScrollView>

    <!-- How-lesson Practice-style: Bengali bubble, hidden English/pronunciation until reveal, stat row -->
    <ScrollView
        android:id="@+id/lecture_practice_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true"
        android:background="@color/lesson_box_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="0dp">

            <TextView
                android:id="@+id/lecture_practice_stat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="12dp"
                android:textColor="#333333"
                android:textSize="13sp"
                android:visibility="gone"
                android:text="" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="10dp">
                    <ImageView
                        android:id="@+id/lecture_practice_avatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:contentDescription="Speaking avatar"
                        android:src="@drawable/ic_avatar_girl"
                        android:scaleType="fitCenter" />
                    <VideoView
                        android:id="@+id/lecture_practice_speaking_video"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:contentDescription="Speaking video" />
                </FrameLayout>
                <TextView
                    android:id="@+id/lecture_practice_bengali"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:padding="14dp"
                    android:background="@drawable/bg_simple_sentence_bubble"
                    android:textSize="18sp"
                    android:textColor="#111111"
                    android:lineSpacingMultiplier="1.2"
                    android:gravity="center"
                    android:text="" />
            </LinearLayout>

            <TextView
                android:id="@+id/lecture_practice_english"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:padding="14dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_simple_sentence_bubble"
                android:textSize="18sp"
                android:textColor="#1565C0"
                android:lineSpacingMultiplier="1.2"
                android:gravity="center"
                android:visibility="gone"
                android:text="" />

            <TextView
                android:id="@+id/lecture_practice_pronunciation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="4dp"
                android:textSize="14sp"
                android:textColor="#666666"
                android:fontStyle="italic"
                android:visibility="gone"
                android:text="" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingVertical="6dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/you_said_label"
                    android:textSize="14sp"
                    android:textColor="#333333" />
                <TextView
                    android:id="@+id/lecture_practice_you_said"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textSize="14sp"
                    android:textColor="#0d6efd"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:text="" />
            </LinearLayout>

            <ImageView
                android:id="@+id/lecture_practice_badge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                android:contentDescription="Result badge" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
