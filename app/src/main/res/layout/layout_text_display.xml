<?xml version="1.0" encoding="utf-8"?>
<!-- Layout 1: Text Display — for introduction, instructions, read-aloud content.
     A scrollable text area that fills the available space.
     Speaker icon next to title: tap to play/pause/stop. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Title row with speaker icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/text_display_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/text_display_speak_button"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="7dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Read aloud"
            android:scaleType="centerInside"
            android:src="@drawable/ic_speak_english" />
    </LinearLayout>

    <!-- Scrollable text body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/text_display_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:textSize="16sp"
            android:textColor="#212121"
            android:lineSpacingMultiplier="1.5"
            android:text="" />
    </ScrollView>
</LinearLayout>
