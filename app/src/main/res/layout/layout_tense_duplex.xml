<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tense_duplex_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lesson_box_background"
    android:paddingTop="8dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/tense_triplet_mode_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:background="@color/lesson_mode_bar_background">

        <ImageButton
            android:id="@+id/tense_triplet_prev_row"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:minWidth="32dp"
            android:minHeight="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous row"
            android:src="@drawable/ic_prev"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <Button
            android:id="@+id/tense_triplet_mode_learning"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="0.25"
            android:minHeight="32dp"
            android:layout_marginHorizontal="2dp"
            android:text="Learning"
            android:textSize="12sp" />

        <Button
            android:id="@+id/tense_triplet_mode_practice"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="0.25"
            android:minHeight="32dp"
            android:layout_marginHorizontal="2dp"
            android:text="Practice"
            android:textSize="12sp" />

        <Button
            android:id="@+id/tense_triplet_mode_test"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="0.25"
            android:minHeight="32dp"
            android:layout_marginHorizontal="2dp"
            android:text="Test"
            android:textSize="12sp" />

        <Button
            android:id="@+id/tense_triplet_mode_vocab"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="0.25"
            android:minHeight="32dp"
            android:layout_marginHorizontal="2dp"
            android:text="V"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/tense_triplet_next_row"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:minWidth="32dp"
            android:minHeight="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next row"
            android:src="@drawable/ic_next"
            android:scaleType="centerInside"
            android:padding="4dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/tense_triplet_content_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/tense_triplet_main_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:background="@color/icon_row_background">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|center_horizontal">

                    <CheckBox
                        android:id="@+id/tense_triplet_show_present"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:buttonTint="@color/lesson_topic_bar_background" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Positive"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textColor="@color/lesson_topic_bar_background"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|center_horizontal">

                    <CheckBox
                        android:id="@+id/tense_triplet_show_past"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:buttonTint="@color/lesson_topic_bar_background" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Negative"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textColor="@color/lesson_topic_bar_background"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tense_triplet_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false" />
        </LinearLayout>

        <include
            android:id="@+id/tense_triplet_vocab_include"
            layout="@layout/layout_lesson_vocab_pronunciation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <include
        android:id="@+id/tense_triplet_control_actions_include"
        layout="@layout/layout_control_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
