<?xml version="1.0" encoding="utf-8"?>
<!-- Inflated into lesson_base_content of layout_lesson_base.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tense_triplet_content_host"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/tense_triplet_main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:background="@color/icon_row_background">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal">

                <CheckBox
                    android:id="@+id/tense_triplet_show_present"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:buttonTint="@color/lesson_topic_bar_background" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bengali meaning"
                    android:textStyle="bold"
                    android:textColor="@color/lesson_topic_bar_background" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal">

                <CheckBox
                    android:id="@+id/tense_triplet_show_past"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:buttonTint="@color/lesson_topic_bar_background" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English sentence"
                    android:textStyle="bold"
                    android:textColor="@color/lesson_topic_bar_background" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/tense_triplet_show_future"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:checked="false"
                android:visibility="gone" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tense_triplet_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <include
        android:id="@+id/tense_triplet_vocab_include"
        layout="@layout/layout_lesson_vocab_pronunciation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</FrameLayout>
