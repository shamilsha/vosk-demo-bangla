<?xml version="1.0" encoding="utf-8"?>
<!--
  Generic 3-column data layout with 2-column display:
  - Top: Learning / Practice tabs
  - Middle: table-like two-column grid (Bengali | English & Hint)
  - Bottom: reusable Start/Stop + Pause/Resume control bar with mic icons (layout_control_actions)

  Each logical row of data has 3 fields:
    1) Bengali
    2) English
    3) Pronunciation / Hint

  Populate rows via the RecyclerView (threecol_recycler) using a row layout that binds those 3 fields.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/lesson_box_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="0dp">

        <!-- Tabs with prev/next on same row (no extra vertical space); compact height -->
        <LinearLayout
            android:id="@+id/threecol_mode_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            android:background="@color/icon_row_background">

            <ImageButton
                android:id="@+id/threecol_prev_row"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="32dp"
                android:minHeight="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous row"
                android:src="@drawable/ic_prev"
                android:scaleType="centerInside"
                android:padding="4dp" />

            <Button
                android:id="@+id/threecol_mode_learning"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.33"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Learning"
                android:textSize="12sp" />

            <Button
                android:id="@+id/threecol_mode_practice"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.33"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Practice"
                android:textSize="12sp" />

            <Button
                android:id="@+id/threecol_mode_test"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.34"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Test"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/threecol_next_row"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="32dp"
                android:minHeight="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next row"
                android:src="@drawable/ic_next"
                android:scaleType="centerInside"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Filter: show only failed & untried sentences (toggle) -->
        <LinearLayout
            android:id="@+id/threecol_row_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@color/icon_row_background">

            <Switch
                android:id="@+id/threecol_weak_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Failed &amp; untried only"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:switchMinWidth="48dp" />
        </LinearLayout>

        <!-- Table header: Bengali | English & Hint + stats on the right -->
        <LinearLayout
            android:id="@+id/threecol_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/lesson_topic_bar_background"
            android:paddingVertical="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/threecol_header_bengali"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Bengali"
                    android:textColor="@color/lesson_topic_bar_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/threecol_header_english"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="English &amp; Hint"
                    android:textColor="@color/lesson_topic_bar_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/threecol_stat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0/0"
                android:textColor="@color/lesson_topic_bar_text"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Scrollable two-column table: populate via adapter. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/threecol_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingVertical="2dp"
            android:clipToPadding="false"
            android:overScrollMode="ifContentScrolls" />

        <!-- Start / Stop + Pause / Resume bar with mic icons (reused layout). -->
        <include
            android:id="@+id/threecol_control_actions_include"
            layout="@layout/layout_control_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>

