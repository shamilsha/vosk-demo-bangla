<?xml version="1.0" encoding="utf-8"?>
<!--
  Conversation bubbles: Person A (left), Person B (right).
  Top: tabs (fixed). Middle: scrollable bubbles only. Bottom: Start/Stop (fixed).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="0dp"
    android:background="@color/lesson_box_background">

        <!-- Tabs: Learning / Practice / Test + prev/next -->
        <LinearLayout
            android:id="@+id/conv_bubble_mode_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            android:background="@color/icon_row_background">

            <ImageButton
                android:id="@+id/conv_bubble_prev_row"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="32dp"
                android:minHeight="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous"
                android:src="@drawable/ic_prev"
                android:scaleType="centerInside"
                android:padding="4dp" />

            <Button
                android:id="@+id/conv_bubble_mode_learning"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.25"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Learning"
                android:textSize="12sp" />

            <Button
                android:id="@+id/conv_bubble_mode_practice"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.25"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Practice"
                android:textSize="12sp" />

            <Button
                android:id="@+id/conv_bubble_mode_test"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.25"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="Test"
                android:textSize="12sp" />

            <Button
                android:id="@+id/conv_bubble_mode_vocab"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="0.25"
                android:minHeight="32dp"
                android:layout_marginHorizontal="2dp"
                android:text="V"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/conv_bubble_next_row"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="32dp"
                android:minHeight="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next"
                android:src="@drawable/ic_next"
                android:scaleType="centerInside"
                android:padding="4dp" />
        </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/conv_bubble_main_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <!-- Failed & untried only (Practice only; hidden in Test) -->
        <LinearLayout
            android:id="@+id/conv_bubble_row_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@color/icon_row_background">

            <Switch
                android:id="@+id/conv_bubble_weak_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Failed &amp; untried only"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:switchMinWidth="48dp" />
        </LinearLayout>

        <!-- Test mode: initiator only (hidden in Learning/Practice) -->
        <LinearLayout
            android:id="@+id/conv_bubble_test_options_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@color/icon_row_background"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initiator"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
            <RadioGroup
                android:id="@+id/conv_bubble_test_initiator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <RadioButton
                    android:id="@+id/conv_bubble_initiator_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App starts"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/conv_bubble_initiator_user"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="User starts"
                    android:textColor="#000000"
                    android:textSize="13sp" />
            </RadioGroup>
        </LinearLayout>

        <!-- Header: stat -->
        <LinearLayout
            android:id="@+id/conv_bubble_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/lesson_topic_bar_background"
            android:paddingVertical="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Person A (left)  ·  Person B (right)"
                android:textColor="@color/lesson_topic_bar_text"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/conv_bubble_stat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textColor="@color/lesson_topic_bar_text"
                android:textSize="12sp" />
        </LinearLayout>

    <!-- Scrollable area only: bubbles -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/conv_bubble_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="0dp"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls" />

        </LinearLayout>

    <!-- V tab: 3-column vocabulary (Word | Pronunciation | Meaning). Same top/bottom bar. -->
    <include
        android:id="@+id/conv_bubble_vocab_include"
        layout="@layout/layout_lesson_vocab_pronunciation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
    </FrameLayout>

    <!-- Bottom: Start/Stop (fixed, always visible) -->
    <include
        android:id="@+id/conv_bubble_control_actions_include"
        layout="@layout/layout_control_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp" />
</LinearLayout>
