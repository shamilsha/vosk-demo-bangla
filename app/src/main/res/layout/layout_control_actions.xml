<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable control bar: Start/Stop and Pause/Resume (toggle buttons, Bootstrap-style). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/control_actions_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingVertical="8dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:background="@color/icon_row_background"
    android:visibility="gone">

    <!-- Start / Stop toggle: primary when Start, danger when Stop (with mic icon) -->
    <Button
        android:id="@+id/control_start_stop"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_control_button"
        android:text="@string/control_start"
        android:textSize="15sp"
        android:textColor="@color/control_btn_text"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:drawableStart="@drawable/ic_mic"
        android:drawablePadding="8dp" />

    <!-- Pause / Resume toggle: warning when Pause, success when Resume (with mic icon) -->
    <Button
        android:id="@+id/control_pause_resume"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_control_button"
        android:text="@string/control_pause"
        android:textSize="15sp"
        android:textColor="@color/control_btn_text"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:drawableStart="@drawable/ic_mic"
        android:drawablePadding="8dp" />
</LinearLayout>
