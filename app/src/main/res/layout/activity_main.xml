<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ═══ TOP BAR (always visible) ═══ -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/lesson_topic_bar_background"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:minHeight="40dp">
            <ImageButton
                android:id="@+id/hamburger_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:scaleType="centerInside"
                android:src="@drawable/ic_menu_hamburger"
                android:padding="6dp" />
            <ImageButton
                android:id="@+id/top_bar_prev_lesson"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/prev_lesson"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mode_bar_triangle_left"
                android:padding="6dp"
                app:tint="@null" />
            <TextView
                android:id="@+id/lesson_topic_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lesson_topic_hint"
                android:textColor="@color/lesson_topic_bar_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="4dp" />
            <TextView
                android:id="@+id/lesson_stat_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="@color/lesson_topic_bar_text"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="0/10 (0%)"
                tools:visibility="visible" />
            <ImageButton
                android:id="@+id/top_bar_next_lesson"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next_lesson"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mode_bar_triangle_right"
                android:padding="6dp"
                app:tint="@null" />
        </LinearLayout>

        <!-- ═══ CONTENT AREA (switchable layouts go here) ═══ -->
        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/lesson_box_background">

            <!-- Default / legacy content (all existing views) -->
            <include layout="@layout/layout_content_legacy" />

        </FrameLayout>

        <!-- ═══ CONTROL ACTIONS (Start / Stop / Pause / Resume) — visible when layout uses them ═══ -->
        <include
            android:id="@+id/control_actions_include"
            layout="@layout/layout_control_actions" />

        <!-- ═══ BOTTOM BAR (always visible) ═══ -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="2dp"
            android:background="@color/icon_row_background">
            <ImageButton
                android:id="@+id/save_list_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/save_list"
                android:scaleType="centerInside"
                android:src="@drawable/ic_save" />
            <ImageButton
                android:id="@+id/load_list_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/load_lesson"
                android:scaleType="centerInside"
                android:src="@drawable/ic_folder_open" />
            <ImageButton
                android:id="@+id/next_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:enabled="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_next" />
            <ImageButton
                android:id="@+id/skip_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/skip"
                android:enabled="false"
                android:scaleType="centerInside"
                android:src="@drawable/ic_skip" />
            <ImageButton
                android:id="@+id/mic_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/start_mic"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mic" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ NAVIGATION DRAWER ═══ -->
    <LinearLayout
        android:id="@+id/nav_drawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/lesson_topic_bar_background"
            android:padding="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lesson Topics"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select a topic to start learning"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:paddingTop="4dp" />
        </LinearLayout>
        <ListView
            android:id="@+id/drawer_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp"
            android:choiceMode="none" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
